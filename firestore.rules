rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public can read all portfolio content (projects, certifications, experiences).
    // Only authenticated users (the admin) can create, update, or delete.
    match /{collection}/{docId} {
      allow read: if collection in ['projects', 'certifications', 'experiences'];
      allow create, update, delete: if request.auth != null
        && collection in ['projects', 'certifications', 'experiences'];
    }
  }
}
